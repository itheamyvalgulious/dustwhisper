
            #version 430
            layout(local_size_x=256, local_size_y=1, local_size_z=1) in;
            uniform int tile_count;

            layout(std430, binding=0) buffer TileMaskBuffer {
                int values[];
            };

            void main() {
                uint index = gl_GlobalInvocationID.x;
                if (index >= uint(max(tile_count, 0))) {
                    return;
                }
                values[int(index)] = 0;
            }
            