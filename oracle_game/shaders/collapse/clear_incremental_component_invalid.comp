#version 430
layout(local_size_x=256, local_size_y=1, local_size_z=1) in;
uniform int component_capacity;
layout(std430, binding=0) buffer InvalidComponents {
    uint invalid_components[];
};
void main() {
    uint index = gl_GlobalInvocationID.x;
    if (index < uint(max(component_capacity, 0))) {
        invalid_components[index] = 0u;
    }
}
