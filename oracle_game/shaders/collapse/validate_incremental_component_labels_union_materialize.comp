#version 430
layout(
    local_size_x={{FORMAL_CONNECTED_TILE_LOCAL_SIZE}},
    local_size_y={{FORMAL_CONNECTED_TILE_LOCAL_SIZE}},
    local_size_z=1
) in;
uniform ivec2 cell_grid_size;
uniform ivec2 world_grid_size;
uniform ivec2 region_origin;
uniform ivec2 tile_grid_size;
uniform int tile_size;
uniform int component_capacity;
uniform uint invalid_generation;
const bool PACKED_INCREMENTAL_SNAPSHOT = {{PACKED_INCREMENTAL_SNAPSHOT}} != 0;
#define INVALID_COMPONENT_GENERATION_VALIDITY {{INVALID_COMPONENT_GENERATION_VALIDITY}}
layout(binding=1) uniform sampler2D snapshot_material_tex;
layout(binding=2) uniform sampler2D snapshot_phase_tex;
layout(r32f, binding=0) writeonly uniform image2D component_label_img;
layout(std430, binding=0) readonly buffer BridgeCellCoreBuffer {
    uint bridge_cell_core[];
};
layout(std430, binding=1) buffer InvalidComponents {
    uint invalid_components[];
};
layout(std430, binding=2) readonly buffer ConnectedTileMask {
    int connected_tiles[];
};
layout(std430, binding=3) readonly buffer ConnectedTileCount {
    uint connected_tile_count[];
};
layout(std430, binding=4) readonly buffer ConnectedTileList {
    ivec2 connected_tile_list[];
};
layout(std430, binding=5) readonly buffer PackedIncrementalSnapshotBuffer {
    uint packed_incremental_snapshot[];
};
layout(std430, binding=6) readonly buffer LocalRoots {
    uint local_roots[];
};
layout(std430, binding=7) readonly buffer UnionParents {
    uint union_parents[];
};

uint find_root(uint label) {
    for (int step = 0; step < 64; ++step) {
        uint parent = union_parents[label - 1u];
        if (parent == 0u || parent == label) {
            return label;
        }
        label = parent;
    }
    return label;
}

void main() {
    uint work_index = gl_WorkGroupID.x;
    if (work_index >= connected_tile_count[0]) {
        return;
    }
    ivec2 tile = connected_tile_list[int(work_index)];
    if (tile.x < 0 || tile.y < 0 || tile.x >= tile_grid_size.x || tile.y >= tile_grid_size.y) {
        return;
    }
    int tile_index = tile.y * tile_grid_size.x + tile.x;
    if (connected_tiles[tile_index] == 0) {
        return;
    }
    ivec2 local_cell = ivec2(gl_LocalInvocationID.xy);
    ivec2 cell = tile * tile_size + local_cell;
    if (
        local_cell.x >= tile_size || local_cell.y >= tile_size ||
        cell.x >= cell_grid_size.x || cell.y >= cell_grid_size.y
    ) {
        return;
    }

    uint local_root = local_roots[cell.y * cell_grid_size.x + cell.x];
    uint root = local_root != 0u ? find_root(local_root) : 0u;
    imageStore(component_label_img, cell, vec4(float(root), 0.0, 0.0, 0.0));
    int label = int(root);
    if (label <= 0 || label > component_capacity) {
        return;
    }

    ivec2 world_cell = region_origin + cell;
    int world_index = world_cell.y * world_grid_size.x + world_cell.x;
    uint live_core = bridge_cell_core[world_index * 5];
    int live_material = int(live_core & 0xFFFFu);
    int live_phase = int((live_core >> 16u) & 0xFFu);
    uint snapshot_core = PACKED_INCREMENTAL_SNAPSHOT
        ? packed_incremental_snapshot[cell.y * cell_grid_size.x + cell.x]
        : 0u;
    int snapshot_material = PACKED_INCREMENTAL_SNAPSHOT
        ? int(snapshot_core & 0xFFFFu)
        : int(texelFetch(snapshot_material_tex, cell, 0).x + 0.5);
    int snapshot_phase = PACKED_INCREMENTAL_SNAPSHOT
        ? int((snapshot_core >> 16u) & 0xFFu)
        : int(texelFetch(snapshot_phase_tex, cell, 0).x + 0.5);
    if (live_material != snapshot_material || live_phase != snapshot_phase) {
#if INVALID_COMPONENT_GENERATION_VALIDITY
        atomicExchange(invalid_components[uint(label - 1)], invalid_generation);
#else
        atomicOr(invalid_components[uint(label - 1)], 1u);
#endif
    }
}
